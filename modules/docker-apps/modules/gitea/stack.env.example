BASE_DOMAIN=my.world

# --- Postgres ----------------------------------------------------------------
POSTGRES_DB=gitea
POSTGRES_USER=gitea
POSTGRES_PASSWORD=<gitea_db_password>

# --- Gitea server ------------------------------------------------------------
GITEA__server__DOMAIN=gitea.${BASE_DOMAIN}
GITEA__server__ROOT_URL=https://${GITEA__server__DOMAIN}/
GITEA__server__SSH_DOMAIN=gitea.${BASE_DOMAIN}

# --- Gitea secrets (generate with: openssl rand -hex 32) --------------------
GITEA__security__SECRET_KEY=<secret_key>
GITEA__security__INTERNAL_TOKEN=<internal_token>

# --- Local admin fallback ----------------------------------------------------
# Used by gitea-init on first boot to create the admin user.
# Keep this account active - it's your fallback if Zitadel is unreachable.
GITEA_ADMIN_USER=<admin_user>
GITEA_ADMIN_PASSWORD=<admin_password>
GITEA_ADMIN_EMAIL=<admin_email>

# --- Migration feature -------------------------------------------------------
#GITEA__migrations__ALLOW_LOCALNETWORKS=true
#GITEA__migrations__SKIP_TLS_VERIFY=true
#GITEA__migrations__ALLOWED_DOMAINS=<some_domain>

# --- Repositry feature -------------------------------------------------------
GITEA__repository__DEFAULT_BRANCH=master

# --- Actions runner ----------------------------------------------------------
# GITEA_RUNNER_REGISTRATION_TOKEN is passed to BOTH gitea (so it accepts the
# token) and gitea-runner (so it can register with it).
# Generate with: openssl rand -hex 24
GITEA_INSTANCE_URL=https://${GITEA__server__DOMAIN}/
GITEA_RUNNER_REGISTRATION_TOKEN=<gitea_runner_token>
GITEA_RUNNER_NAME=docker-runner

# --- Zitadel OIDC -----------------------------------------------------------
ZITADEL_CLIENT_ID=<gitea_client_id>
ZITADEL_CLIENT_SECRET=<gitea_client_secret>
ZITADEL_DISCOVERY_URL=https://zitadel.my.world/.well-known/openid-configuration
ZITADEL_PROVIDER_NAME=Zitadel
